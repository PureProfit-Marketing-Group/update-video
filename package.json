{
  "name": "update-video",
  "version": "0.1.1",
  "description": "Auto-generated \"What's New\" videos for your app — powered by Remotion and Claude AI",
  "scripts": {
    "dev": "remotion studio",
    "build": "tsup",
    "build:remotion": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "main": "./dist/sdk.js",
  "module": "./dist/sdk.mjs",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.mjs",
      "require": "./dist/sdk.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./capture": {
      "types": "./dist/capture.d.ts",
      "import": "./dist/capture.mjs",
      "require": "./dist/capture.js"
    },
    "./compositions": {
      "types": "./dist/compositions.d.ts",
      "import": "./dist/compositions.mjs",
      "require": "./dist/compositions.js"
    },
    "./consolidation": {
      "types": "./dist/consolidation.d.ts",
      "import": "./dist/consolidation.mjs",
      "require": "./dist/consolidation.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "repository": {},
  "license": "MIT",
  "keywords": [
    "remotion",
    "changelog",
    "whats-new",
    "update-video",
    "release-notes",
    "react"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "remotion": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "@remotion/player": {
      "optional": true
    },
    "@remotion/transitions": {
      "optional": true
    },
    "@remotion/google-fonts": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "playwright": "^1.58.0"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/eslint-config-flat": "^4.0.0",
    "@remotion/google-fonts": "4.0.431",
    "@remotion/player": "^4.0.435",
    "@remotion/transitions": "4.0.431",
    "@remotion/zod-types": "^4.0.0",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  }
}
